{
  "name": "@pre-cr/core",
  "version": "0.1.0",
  "description": "Core parsing and validation logic for Pre-CR Suite",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext ts",
    "clean": "rm -rf dist coverage"
  },
  "keywords": [
    "coverage",
    "lcov",
    "istanbul",
    "testing"
  ],
  "author": "Jakye Amos <jakyejobs@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jakyeamos/pre-cr-suite",
    "directory": "packages/core"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitest/coverage-v8": "^1.1.0",
    "eslint": "^8.55.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
